{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "App: Import OSM",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "import_osm.src.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/import_osm/local.env",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "LOG_LEVEL": "DEBUG"
            }
        },
        {
            "name": "App: Export To OSM",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/export_to_osm/src/main.py",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/export_to_osm/local.env",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "LOG_LEVEL": "DEBUG"
            }
        }
    ]
}
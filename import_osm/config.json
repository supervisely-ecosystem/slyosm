{
  "type": "app",
  "version": "2.0.0",
  "name": "Satellite, DTM & OSM Downloader",
  "description": "Download georeferenced satellite imagery, DTM elevation tiles, and OpenStreetMap vector annotations into Supervisely datasets.",
  "icon_cover": true,
  "poster": "https://github.com/supervisely-ecosystem/slyosm/releases/download/0.0.1/poster-satellite-dtm-osm-downloader-res.jpg",
  "icon": "https://github.com/supervisely-ecosystem/slyosm/releases/download/0.0.1/icon-satellite-dtm-osm-downloader-res.jpg",
  "categories": ["import", "images", "synthetic", "data operations"],
  "need_gpu": false,
  "community_agent": true,
  "docker_image": "supervisely/slyosm:0.0.3",
  "instance_version": "6.15.60",
  "headless": false,
  "entrypoint": "python -m uvicorn import_osm.src.main:app --host 0.0.0.0 --port 8000",
  "port": 8000,
  "task_location": "workspace_tasks"
}

{
  "type": "app",
  "version": "2.0.0",
  "name": "Export to OSM Format",
  "description": "Export Supervisely annotated datasets with geo metadata to OSM XML files alongside original images and annotations in Supervisely format.",
  "poster": "https://github.com/supervisely-ecosystem/slyosm/releases/download/0.0.1/export-poster.png",
  "icon": "https://github.com/supervisely-ecosystem/slyosm/releases/download/0.0.1/export-icon.png",
  "categories": ["export", "images", "data operations"],
  "need_gpu": false,
  "community_agent": true,
  "docker_image": "supervisely/slyosm:0.0.3",
  "instance_version": "6.15.60",
  "headless": true,
  "entrypoint": "python export_to_osm/src/main.py",
  "port": 8000,
  "context_menu": {
    "context_root": "Download as",
    "target": ["images_dataset", "images_project"]
  },
  "task_location": "workspace_tasks"
}
